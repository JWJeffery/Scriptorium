generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum DocumentKind {
  PDF
  DOCX
  OFFICE
  GOOGLE_DOC
  GOOGLE_SHEET
  GOOGLE_SLIDE
  TXT
  MARKDOWN
  OTHER
}

enum SnapshotKind {
  ORIGINAL
  PDF_RENDERING
  TEXT_EXTRACTION
  HTML_RENDERING
  IMAGE_SCAN
}

enum PageNumberingSystem {
  ARABIC
  ROMAN
  UNNUMBERED
  APPENDIX
  FOLIO
  CUSTOM
}

enum MappingConfidence {
  IMPORTED
  INFERRED
  USER_CONFIRMED
  UNCERTAIN
}

enum ResearchThreadItemType {
  DOCUMENT
  ANNOTATION
  CITATION
  SOURCE
  NOTE
}

model Document {
  id               String            @id @default(cuid())
  title            String            @db.VarChar(512)
  originalFilename String?           @db.VarChar(512)
  kind             DocumentKind
  mediaType        String?           @db.VarChar(255)
  storageKey       String?           @db.VarChar(1024)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  versions         DocumentVersion[]
  sources          Source[]
  annotations      Annotation[]

  @@index([title])
}

model DocumentVersion {
  id              String       @id @default(cuid())
  documentId      String
  document        Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sourceChecksum  String?      @db.VarChar(255)
  snapshotKind    SnapshotKind
  snapshotKey     String?      @db.VarChar(1024)
  extractionState String       @default("pending") @db.VarChar(255)
  createdAt       DateTime     @default(now())
  pages           PageMap[]
  textSpans       TextSpan[]
  annotations     Annotation[]

  @@index([documentId])
}

model Source {
  id          String     @id @default(cuid())
  documentId  String?
  document    Document?  @relation(fields: [documentId], references: [id], onDelete: SetNull)
  shortTitle  String?    @db.VarChar(512)
  cslJson     Json
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  citations   Citation[]

  @@index([documentId])
}

model PageMap {
  id              String              @id @default(cuid())
  versionId       String
  version         DocumentVersion     @relation(fields: [versionId], references: [id], onDelete: Cascade)
  pdfPageIndex    Int
  visibleLabel    String?             @db.VarChar(64)
  bookPageLabel   String?             @db.VarChar(64)
  numberingSystem PageNumberingSystem @default(ARABIC)
  confidence      MappingConfidence   @default(UNCERTAIN)
  note            String?             @db.Text
  annotations     Annotation[]
  textSpans       TextSpan[]

  @@unique([versionId, pdfPageIndex])
  @@index([bookPageLabel])
}

model TextSpan {
  id        String          @id @default(cuid())
  versionId String
  version   DocumentVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  pageMapId String?
  pageMap   PageMap?        @relation(fields: [pageMapId], references: [id], onDelete: SetNull)
  text      String          @db.LongText
  anchor    Json?
  createdAt DateTime        @default(now())

  @@index([versionId])
  @@index([pageMapId])
}

model Annotation {
  id           String          @id @default(cuid())
  documentId   String
  document     Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionId    String
  version      DocumentVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  pageMapId    String?
  pageMap      PageMap?        @relation(fields: [pageMapId], references: [id], onDelete: SetNull)
  colorKey     String          @db.VarChar(64)
  selectedText String          @db.LongText
  note         String?         @db.LongText
  anchor       Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  citations    Citation[]
  tags         AnnotationTag[]

  @@index([documentId])
  @@index([versionId])
  @@index([pageMapId])
  @@index([colorKey])
}

model AnnotationTag {
  id           String     @id @default(cuid())
  annotationId String
  annotation   Annotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  value        String     @db.VarChar(128)

  @@unique([annotationId, value])
  @@index([value])
}

model Citation {
  id            String      @id @default(cuid())
  sourceId      String
  source        Source      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  annotationId  String?
  annotation    Annotation? @relation(fields: [annotationId], references: [id], onDelete: SetNull)
  styleId       String      @db.VarChar(128)
  locale        String      @default("en-US") @db.VarChar(32)
  locatorType   String      @default("page") @db.VarChar(64)
  locatorValue  String?     @db.VarChar(255)
  prefix        String?     @db.Text
  suffix        String?     @db.Text
  generatedText String      @db.LongText
  createdAt     DateTime    @default(now())

  @@index([sourceId])
  @@index([annotationId])
  @@index([styleId])
}

model ResearchThread {
  id          String               @id @default(cuid())
  title       String               @db.VarChar(512)
  description String?              @db.LongText
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  items       ResearchThreadItem[]
  tags        ResearchThreadTag[]
}

model ResearchThreadTag {
  id               String         @id @default(cuid())
  researchThreadId String
  researchThread   ResearchThread @relation(fields: [researchThreadId], references: [id], onDelete: Cascade)
  value            String         @db.VarChar(128)

  @@unique([researchThreadId, value])
  @@index([value])
}

model ResearchThreadItem {
  id               String                 @id @default(cuid())
  researchThreadId String
  researchThread   ResearchThread         @relation(fields: [researchThreadId], references: [id], onDelete: Cascade)
  itemType         ResearchThreadItemType
  itemId           String
  note             String?                @db.LongText
  orderIndex       Int                    @default(0)

  @@index([researchThreadId])
  @@index([itemType, itemId])
}

model QueryLog {
  id        String   @id @default(cuid())
  query     String   @db.LongText
  mode      String   @db.VarChar(128)
  filters   Json?
  resultIds Json?
  createdAt DateTime @default(now())
}
