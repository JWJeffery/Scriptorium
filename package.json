{
  "name": "scriptorium",
  "private": true,
  "version": "0.0.1",
  "description": "Scholarly reading, annotation, citation, and research-memory platform.",
  "scripts": {
    "dev": "pnpm --filter @scriptorium/web dev",
    "build": "pnpm --filter @scriptorium/web build",
    "lint": "pnpm --filter @scriptorium/web lint",
    "typecheck": "pnpm --filter @scriptorium/web typecheck",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "latest",
    "typescript": "latest"
  },
  "packageManager": "pnpm@latest"
}
